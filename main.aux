\@writefile{lof}{\contentsline {figure}{\numberline {B.1}{\ignorespaces Algorithm comparison: DQN vs PPO across four noise levels (no safety supervisor). Top-left: DQN maintains lower failure rates at every noise level. Top-right: risk-adjusted reward (crash-penalised at $-500$) shows DQN winning decisively. Bottom-left: PPO achieves higher jackpot rates but at unacceptable safety cost. Bottom-right: DQN's jackpot-to-failure ratio is dramatically higher, demonstrating superior reliability.}}{76}{figure.B.1}\protected@file@percent }
\newlabel{fig:ppo_comparison}{{B.1}{76}{Algorithm comparison: DQN vs PPO across four noise levels (no safety supervisor). Top-left: DQN maintains lower failure rates at every noise level. Top-right: risk-adjusted reward (crash-penalised at $-500$) shows DQN winning decisively. Bottom-left: PPO achieves higher jackpot rates but at unacceptable safety cost. Bottom-right: DQN's jackpot-to-failure ratio is dramatically higher, demonstrating superior reliability}{figure.B.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {B.2}{\ignorespaces Statistical analysis of DQN vs PPO. Left: risk-adjusted reward delta (DQN $-$ PPO), with DQN advantaged at all noise levels when crash penalties are included. Centre: Cohen's $d$ on raw reward, showing small to negligible effect sizes. Right: head-to-head scorecard, where DQN wins 3/5 metrics including failure rate and risk-adjusted reward.}}{77}{figure.B.2}\protected@file@percent }
\newlabel{fig:ppo_statistical}{{B.2}{77}{Statistical analysis of DQN vs PPO. Left: risk-adjusted reward delta (DQN $-$ PPO), with DQN advantaged at all noise levels when crash penalties are included. Centre: Cohen's $d$ on raw reward, showing small to negligible effect sizes. Right: head-to-head scorecard, where DQN wins 3/5 metrics including failure rate and risk-adjusted reward}{figure.B.2}{}}
